{
  "description": "ADLC hooks — preflight on session start, flail-detection after edits/commands, gate-evidence audit on stop (all advisory), and a blocking rail-guard that denies edits to frozen rail paths declared in tickets. All no-op unless the repo is ADLC-initialized; rail enforcement additionally no-ops until a ticket declares rails.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/adlc-hook.mjs\" rails",
            "timeout": 15
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/adlc-hook.mjs\" preflight",
            "timeout": 60
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/adlc-hook.mjs\" flail",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/adlc-hook.mjs\" manifest",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
