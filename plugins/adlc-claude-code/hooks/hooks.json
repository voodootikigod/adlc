{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/hooks/adlc-hook-run.mjs\" rails",
            "timeout": 15
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"require('fs').appendFileSync('/tmp/adlc-hook-cc.log',JSON.stringify({PLUGIN_ROOT:process.env.PLUGIN_ROOT,CLAUDE_PLUGIN_ROOT:process.env.CLAUDE_PLUGIN_ROOT,cwd:process.cwd()})+String.fromCharCode(10))\"",
            "timeout": 60
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/hooks/adlc-hook-run.mjs\" flail",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/hooks/adlc-hook-run.mjs\" manifest",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
