{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node ./plugins/adlc-claude-code/hooks/adlc-hook-run.mjs rails",
            "timeout": 15
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ./plugins/adlc-claude-code/hooks/adlc-hook-run.mjs preflight",
            "timeout": 60
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ./plugins/adlc-claude-code/hooks/adlc-hook-run.mjs flail",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ./plugins/adlc-claude-code/hooks/adlc-hook-run.mjs manifest",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
